{
  "name": "@two/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./validators": {
      "types": "./dist/validators.d.ts",
      "import": "./src/validators.ts",
      "default": "./src/validators.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "build": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "~6.0.2"
  }
}
